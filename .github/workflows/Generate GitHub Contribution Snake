name: Generate GitHub Contribution Snake

on:
  schedule:
    - cron: '0 0 * * *' # প্রতিদিন 00:00 UTC তে রান হবে
  workflow_dispatch: # ম্যানুয়ালি রান করার জন্য

jobs:
  generate-snake:
    runs-on: ubuntu-latest

    steps:
      # Checkout repo
      - name: Checkout repository
        uses: actions/checkout@v3

      # Generate Snake from GitHub Contribution Grid
      - name: Generate Snake
        uses: Platane/snk@v3.4.1
        with:
          github_user_name: "mohammad-sheikh-shahinur-rahman" # <-- আপনার GitHub username
          github_token: ${{ secrets.GITHUB_TOKEN }}
          output: ./output/github-contribution-grid-snake.svg

      # Commit SVG
      - name: Commit SVG
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          git add ./output/github-contribution-grid-snake.svg
          git commit -m "Update contribution snake" || echo "No changes to commit"
          git push
